# 数据库
DATABASE_URL=postgresql://cloudserve:cloudserve_dev@localhost:5432/cloudserve

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:8080

# 服务器
PORT=3000
NODE_ENV=development

# 阿里云号码认证服务（短信验证码）
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=速通互联验证码
SMS_TEMPLATE_CODE=100001

# 微信支付 V3（商户号申请后填写）
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_SERIAL_NO=
WECHAT_PRIVATE_KEY_PATH=
WECHAT_NOTIFY_URL=http://your-domain.com/api/pay/wechat/callback

# 支付宝（商户号申请后填写）
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=http://your-domain.com/api/pay/alipay/callback
